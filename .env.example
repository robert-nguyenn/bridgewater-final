# Anthropic API. Required.
ANTHROPIC_API_KEY=

# FRED. Required for any tool call hitting fredapi.
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# HuggingFace. Required for datasets.load_dataset on gated mirrors.
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Perplexity. Optional, only for the stretch ScenarioAgent news pull.
PERPLEXITY_API_KEY=

# Run config
LOG_LEVEL=INFO
CACHE_DIR=.cache
